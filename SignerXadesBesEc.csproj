<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <RootNamespace>SignerXadesBesEc</RootNamespace>
    <AssemblyName>SignerXadesBesEc</AssemblyName>
    <Nullable>enable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <LangVersion>latest</LangVersion>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="System.Security.Cryptography.Xml" Version="10.0.6" />
  </ItemGroup>

  <!-- Exclude the tests subfolder — it has its own project file -->
  <ItemGroup>
    <Compile Remove="tests\**\*.cs" />
    <None Include="README.md" />
  </ItemGroup>

</Project>